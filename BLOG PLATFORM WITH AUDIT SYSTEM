--QUEIRES
--TRIGGERS AUTO UPDATE UPDATE_AT 
CREATE OR REPLACE FUNCTION UPDATE_TIMESTAMP()
RETURNS TRIGGER AS $$
BEGIN 
NEW.UPDATED_AT = CURRENT_TIMESTAMP;
RETURN NEW;
END;
$$ LANGUAGE PLPGSQL;

CREATE TRIGGER TRG_UPDATE_TIMESTAMP
BEFORE UPDATE ON POSTS
FOR EACH ROW 
EXECUTE FUNCTION UPDATE_TIMESTAMP();

--TRIGGERS AUDIT TRAIL FOR POSTS 
CREATE OR REPLACE FUNCTION POST_AUDIT_FUNC()
RETURNS TRIGGER AS $$
BEGIN 
INSERT INTO POST_AUDIT(POST_ID,ACTION)
VALUES(NEW.POST_ID,'UPDATED');
RETURN NEW;
END;
$$ LANGUAGE PLPGSQL;

CREATE TRIGGER TRG_POST_AUDIT
AFTER UPDATE ON POSTS 
FOR EACH ROW 
EXECUTE FUNCTION POST_AUDIT_FUNC();

--TRIGGER ON INCREMENT COMMENT COUNT
CREATE OR REPLACE FUNCTION update_comment_count()
RETURNS TRIGGER AS $$
BEGIN
UPDATE posts
SET comment_count = comment_count + 1
WHERE post_id = NEW.post_id;
RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_comment_count
AFTER INSERT ON comments
FOR EACH ROW
EXECUTE FUNCTION update_comment_count();
--TRIGGER ON  Prevent Deleting Posts with Comments
CREATE OR REPLACE FUNCTION prevent_delete()
RETURNS TRIGGER AS $$
BEGIN
IF EXISTS (SELECT 1 FROM comments WHERE post_id = OLD.post_id) THEN
RAISE EXCEPTION 'Cannot delete post with comments';
END IF;
RETURN OLD;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_prevent_delete
BEFORE DELETE ON posts
FOR EACH ROW
EXECUTE FUNCTION prevent_delete();















