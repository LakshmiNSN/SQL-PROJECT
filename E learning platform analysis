--sub-queries(users who completed more courses than query)
SELECT user_id
FROM completions
GROUP BY user_id
HAVING COUNT(course_id) >
(
    SELECT AVG(cnt)
    FROM (
        SELECT COUNT(course_id) AS cnt
        FROM completions
        GROUP BY user_id
    ) AS sub
);

--cte(Calculate how many users completed each course.)
WITH completion_counts AS (
    SELECT 
        course_id,
        COUNT(user_id) AS total_completions
    FROM completions
    GROUP BY course_id
)

SELECT 
    c.course_name,
    cc.total_completions
FROM completion_counts cc
JOIN courses c
ON cc.course_id = c.course_id;
--Recursive CTE – Course Prerequisite Chain
WITH RECURSIVE course_chain AS (
    
    SELECT 
        course_id,
        course_name,
        prerequisite_course_id
    FROM courses
    WHERE prerequisite_course_id IS NULL

    UNION ALL

    SELECT 
        c.course_id,
        c.course_name,
        c.prerequisite_course_id
    FROM courses c
    JOIN course_chain cc
    ON c.prerequisite_course_id = cc.course_id
)

SELECT * FROM course_chain;

--UNION – Combine Free and Paid Users
SELECT user_name, user_type
FROM users
WHERE user_type = 'free'

UNION

SELECT user_name, user_type
FROM users
WHERE user_type = 'paid';
--INTERSECT – Users who took both Python and SQL courses
SELECT user_id
FROM completions c
JOIN courses co
ON c.course_id = co.course_id
WHERE co.course_name LIKE '%Python%'

INTERSECT

SELECT user_id
FROM completions c
JOIN courses co
ON c.course_id = co.course_id
WHERE co.course_name LIKE '%Sql%';
