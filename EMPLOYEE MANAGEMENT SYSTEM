CREATE TABLE EMPLOYEES(
EMP_ID SERIAL PRIMARY KEY,
FIRST_NAME VARCHAR(50),
LAST_NAME VARCHAR(50),
BIRTH_DATE DATE,
PHONE VARCHAR(15),
HIRE_DATE DATE,
AGE INT
);

INSERT INTO EMPLOYEES(FIRST_NAME,LAST_NAME,BIRTH_DATE,PHONE,HIRE_DATE,AGE)
SELECT 
'FIRST_' || GS,
'LAST_' || GS,
DATE '2004-06-07' +(GS*300),
'999-000-' || LPAD(GS::text, 4, '0'),
CURRENT_DATE -(GS * 40),
18+ (GS % 5)
FROM GENERATE_SERIES(1,10)AS GS;


CREATE TABLE SALARIES(
SAL_ID SERIAL PRIMARY KEY,
EMP_ID INT REFERENCES EMPLOYEES(EMP_ID),
BASE_SALARY NUMERIC(10,2),
BONUS_PERCENT INT
);

INSERT INTO SALARIES (EMP_ID,BASE_SALARY,BONUS_PERCENT)
SELECT 
GS,
30000 +(GS *1500), --INCREASING THE SALARY 
(GS * 10)+5-- 1-9 AND ADD 5
FROM GENERATE_SERIES(1,10)AS GS;

CREATE TABLE ATTENDANCE(
ATT_ID SERIAL PRIMARY KEY,
EMP_ID INT REFERENCES EMPLOYEES(EMP_ID),
WORK_DATE DATE,
HOURS_WORKED INT
);


INSERT INTO attendance (emp_id, work_date, hours_worked)
SELECT 
    emp_id,
    CURRENT_DATE - gs.day,
    (5 + (emp_id % 4))  -- hours worked (random pattern)
FROM generate_series(1,30) AS gs(day)
CROSS JOIN (SELECT emp_id FROM employees) e;

--QUEIRES tenure, age, monthly salary, bonus
--TENURE (YEARLY WORKED)
SELECT 
EMP_ID,
FIRST_NAME,
LAST_NAME,
AGE(CURRENT_DATE,HIRE_DATE)AS TENURE
FROM EMPLOYEES;

--MONTHLY SALARY & BONUS_AMOUNT
SELECT 
E.EMP_ID ,
CONCAT(E.FIRST_NAME ,'',E.LAST_NAME)AS NAME,
S.BASE_SALARY,
S.BONUS_PERCENT,
(S.BASE_SALARY * S.BONUS_PERCENT /100) AS BONUS_AMOUNT,
(S.BASE_SALARY /12)
FROM EMPLOYEES E
JOIN SALARIES S ON E.EMP_ID = S.SAL_ID;

--Format: names (Title Case), phone numbers
SELECT 
EMP_ID,
INITCAP(FIRST_NAME)AS FIRST_NAME,
INITCAP(LAST_NAME)AS LAST_NAME,
REPLACE(PHONE,'-','')AS CLEAN_PHONE
FROM EMPLOYEES;

--Find: employees hired in last year, birthdays this month
SELECT*
FROM EMPLOYEES
WHERE HIRE_DATE >= CURRENT_DATE - INTERVAL '1YEAR';
--BIRTHDAYS THIS MONTH
SELECT *
FROM EMPLOYEES
WHERE EXTRACT(MONTH FROM BIRTH_DATE) = EXTRACT(MONTH FROM CURRENT_DATE);

---Generate email addresses from names
SELECT 
    emp_id,
    LOWER(first_name || '.' || last_name || '@company.com') AS email
FROM employees;


