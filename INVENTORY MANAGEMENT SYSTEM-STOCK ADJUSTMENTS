--inventory management stock adjustments 
CREATE TABLE EMPLOYEES(
EMP_ID INT PRIMARY KEY,
NAME VARCHAR(50),
SALARY INT
);

INSERT INTO EMPLOYEES(EMP_ID,NAME,SALARY)
SELECT 
     GS,
	 'EMPLOYEE_' || GS,
	 30000 +GS *1000
FROM GENERATE_SERIES(1,10) AS GS;

CREATE TABLE ORDERS(
ID INT PRIMARY KEY,
ORDER_DATE DATE,
STATUS TEXT
);

INSERT INTO ORDERS(ID,ORDER_DATE,STATUS)
SELECT 
     GS,
	 CURRENT_DATE -GS * 5,
	 'PENDING' 
FROM GENERATE_SERIES(1,10)AS GS;

CREATE TABLE PRODUCTS(
ID INT PRIMARY KEY,
NAME TEXT,
PRICE INT,
SUPPLIER_PRICE INT ,
CATEGORY TEXT,
IS_ACTIVE BOOLEAN 
);

INSERT INTO PRODUCTS
SELECT 
     GS,
	 'PRODUCT_' || GS,
	 100*GS,
	 90*GS,
	 CASE WHEN GS %2=0 THEN 'ELECTRONICS' ELSE 'CLOTHING'END,
	 TRUE
FROM GENERATE_SERIES(1,10)AS GS;

CREATE TABLE USERS(
ID INT PRIMARY KEY,
LAST_LOGIN DATE
);

INSERT INTO USERS
SELECT 
     GS,
	 CURRENT_DATE -(GS * 400)
FROM GENERATE_SERIES(1,10)AS GS;

CREATE TABLE STOCK_MOVEMENTS(
ID INT PRIMARY KEY,
PRODUCT_ID INT,
QUANTITY INT,
MOVEMENT_DATE DATE
);

INSERT INTO STOCK_MOVEMENTS
SELECT 
     GS,
	 GS,
	 10 * GS,	 
	 CURRENT_DATE -GS
FROM GENERATE_SERIES(1,10)AS GS;

CREATE TABLE CURRENT_INVENTORY(
PRODUCT_ID INT,
STOCK INT
);

INSERT INTO CURRENT_INVENTORY
SELECT 
  GS,
  50
FROM GENERATE_SERIES(1,10)AS GS;

--operations(queries)update and delete
--update stock levels based on sales 
UPDATE CURRENT_INVENTORY CI
SET STOCK = STOCK  - SM.QUANTITY
FROM STOCK_MOVEMENTS SM
WHERE CI.PRODUCT_ID=SM.PRODUCT_ID;

--Delete discontinued products
DELETE FROM PRODUCTS
WHERE IS_ACTIVE ='FALSE';

--BULK UPDATE PRICES BY CATEGORY 
UPDATE PRODUCTS 
SET PRICE = PRICE * 1.15
WHERE CATEGORY ='ELECTRONICS';

--ARCHIVE OLD TRANSACTIONS 
DELETE FROM STOCK_MOVEMENTS
WHERE MOVEMENT_DATE <CURRENT_DATE - INTERVAL '1YEAR';

--Soft delete (set is_active = false)
UPDATE products
SET is_active=false
WHERE id=5;








