--bussiness intelligence dashboards
CREATE TABLE customers(
customer_id INT PRIMARY KEY,
customer_name TEXT,
created_at DATE
);

CREATE TABLE products(
product_id INT PRIMARY KEY,
product_name TEXT,
price NUMERIC
);

CREATE TABLE orders(
order_id INT PRIMARY KEY,
customer_id INT,
order_date DATE
);

CREATE TABLE order_items(
order_item_id INT PRIMARY KEY,
order_id INT,
product_id INT,
quantity INT
);

INSERT INTO customers
SELECT g, 'Customer '||g, CURRENT_DATE - g
FROM generate_series(1,200) g;


INSERT INTO products
SELECT g, 'Product '||g, (g*10)
FROM generate_series(1,50) g;

INSERT INTO orders
SELECT g, (g%200)+1, CURRENT_DATE - (g%30)
FROM generate_series(1,500) g;


INSERT INTO order_items
SELECT g, (g%500)+1, (g%50)+1, (g%5)+1
FROM generate_series(1,1000) g;

--queries 
--(customer lifetime value(total spent per customers))

CREATE VIEW vw_customer_lifetime_value AS
SELECT c.customer_id,
c.customer_name,
SUM(p.price*oi.quantity) AS total_spent
FROM customers c
JOIN orders o ON c.customer_id=o.customer_id
JOIN order_items oi ON o.order_id = oi.order_id
JOIN products p ON oi.product_id = p.product_id
GROUP BY c.customer_id,c.customer_name;

--Complex View
--Product Performance
CREATE VIEW vw_product_performance AS
SELECT p.product_id,
p.product_name,
SUM(oi.quantity) AS total_units,
SUM(p.price*oi.quantity) AS total_sales
FROM products p
JOIN order_items oi ON p.product_id=oi.product_id
GROUP BY p.product_id,p.product_name;

--montly revenue view
CREATE VIEW vw_monthly_revenue AS
SELECT DATE_TRUNC('month',o.order_date) AS month,
SUM(p.price*oi.quantity) AS revenue
FROM orders o
JOIN order_items oi ON o.order_id=oi.order_id
JOIN products p ON oi.product_id=p.product_id
GROUP BY month;
--TOP CUSTOMERS VIEW
CREATE VIEW vw_top_customers AS
SELECT *
FROM vw_customer_lifetime_value
ORDER BY total_spent DESC
LIMIT 100;
--MATERALIZED VIEW
--SALES SUMMARY
SELECT DATE_TRUNC('day',o.order_date) AS day,
SUM(p.price*oi.quantity) AS daily_sales
FROM orders o
JOIN order_items oi ON o.order_id=oi.order_id
JOIN products p ON oi.product_id=p.product_id
GROUP BY day;
CREATE MATERIALIZED VIEW mv_sales_summary AS
SELECT DATE_TRUNC('day',o.order_date) AS day,
SUM(p.price*oi.quantity) AS daily_sales
FROM orders o
JOIN order_items oi ON o.order_id=oi.order_id
JOIN products p ON oi.product_id=p.product_id
GROUP BY day;
--Refresh Materialized View
REFRESH MATERIALIZED VIEW mv_sales_summary;
--Performance Comparison
EXPLAIN ANALYZE
SELECT * FROM vw_customer_lifetime_value;

EXPLAIN ANALYZE
SELECT * FROM mv_sales_summary;














