SELECT 
(GS%2)+1 AS ACCOUNT_ID,
(GS%3)+1 AS CATEGORY_ID,
(GS%100)::NUMERIC(10,2)AS AMOUNT,
DATE '2026-01-03'+ GS AS TRANSACTION_DATE,
'TRANSACTIONS_RECORDS' AS NOTE
FROM GENERATE_SERIES(1,30)AS GS;

---INTERVIEW QUESTIONS
--INTERMEDIATE 
--JOIN Query
SELECT A.ACCOUNT_NAME,C.CATEGORY_NAME,T.TRANSACTION_ID
FROM TRANSACTIONS T 
JOIN ACCOUNTS A ON T.ACCOUNT_ID =A.ACCOUNT_ID
JOIN CATEGORIES C ON T.CATEGORY_ID = C.CATEGORY_ID;

--TOTAL EXPENSES 
SELECT SUM(AMOUNT)AS TOTAL 
FROM TRANSACTIONS T
JOIN CATEGORIES C ON T.CATEGORY_ID = C.CATEGORY_ID
GROUP BY CATEGORY_TYPE ='EXPENSES';

--INCOME VS EXPENSES 
SELECT C.CATEGORY_TYPE,SUM(AMOUNT)
FROM TRANSACTIONS T 
JOIN CATEGORIES C ON T.CATEGORY_ID =C.CATEGORY_ID 
GROUP BY C.CATEGORY_TYPE;

--Monthly Spending
SELECT DATE_TRUNC('MONTH',TRANSACTION_DATE)AS MONTH
FROM TRANSACTIONS T
GROUP BY MONTH;

--Date Range
SELECT *
FROM TRANSACTIONS 
WHERE TRANSACTION_DATE BETWEEN '2026-03-18' AND '2026-04-02';

--WHERE vs HAVING
SELECT CATEGORY_ID ,SUM(AMOUNT)
FROM TRANSACTIONS 
GROUP BY CATEGORY_ID 
HAVING SUM(AMOUNT)>500;

--Top 3 Transactions
SELECT *
FROM TRANSACTIONS 
ORDER BY AMOUNT DESC 
LIMIT 3;

--ADVANCED
--Highest Expense Category
SELECT CATEGORY_NAME ,SUM(AMOUNT)AS TOTAL
FROM TRANSACTIONS T
JOIN CATEGORIES C ON T.CATEGORY_ID = C.CATEGORY_ID 
WHERE C.CATEGORY_TYPE ='EXPENSES'
GROUP BY CATEGORY_NAME 
ORDER BY TOTAL DESC
LIMIT 1;

--Account Balance
SELECT account_name,
SUM(CASE 
    WHEN c.category_type = 'INCOME' THEN t.amount
    ELSE -t.amount
END) AS balance
FROM transactions t
JOIN accounts a ON t.account_id = a.account_id
JOIN categories c ON t.category_id = c.category_id
GROUP BY account_name;

--Scenario-Based Questions (Very Important ⭐)
--“How much money I spent on shopping last month?”
SELECT SUM(AMOUNT)
FROM TRANSACTIONS T
JOIN CATEGORIES C ON T.CATEGORY_ID = C.CATEGORY_ID
WHERE CATEGORY_NAME = 'SHOPPING'
AND DATE_TRUNC('MONTH',TRANSACTION_DATE)=DATE_TRUNC('MONTH',CURRENT_DATE -INTERVAL '1MONTH');
--Daily  Spending
SELECT TRANSACTION_DATE,SUM(AMOUNT)
FROM TRANSACTIONS 
GROUP BY TRANSACTION_DATE;
--Last 5 Transactions
SELECT *
FROM TRANSACTIONS 
ORDER BY TRANSACTION_DATE DESC
LIMIT 5;






