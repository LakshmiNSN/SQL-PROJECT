INSERT INTO TRANSACTIONS(ACCOUNT_ID,CATEGORY_ID,AMOUNT,TRANSACTION_DATE,NOTE)
SELECT 
(GS%2)+1 AS ACCOUNT_ID,
(GS%3)+1 AS CATEGORY_ID,
(GS%100)::NUMERIC(10,2)AS AMOUNT,
DATE '2026-01-03'+ GS AS TRANSACTION_DATE,
'TRANSACTIONS_RECORDS' AS NOTE
FROM GENERATE_SERIES(1,30)AS GS;


