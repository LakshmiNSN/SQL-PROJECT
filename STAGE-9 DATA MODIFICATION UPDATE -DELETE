--1.PRACTICAL ASSIGNMENTS
--Targeted UPDATE:
--GIVE 10% RAISE TO SALES EMPLOYEE
UPDATE EMPLOYEES 
SET SALARY = SALARY *1.10
WHERE DEPARTMENT = 'SALES';

--UPDATE ORDERS OLDER THAN 30 DAYS 
UPDATE ORDERS
SET STATUS ='DELAYED'
WHERE ORDER_DATE <CURRENT_DATE - 30;

--CAPITALIZE ALL PRODUCST NAMES
UPDATE PRODUCTS 
SET NAME = UPPER(NAME);

--2.UPDATE with JOIN
UPDATE PRODUCTS P
SET PRICE = S.SUPPLIER_PRICE 
FROM PRODUCTS S
WHERE P.ID = S.ID;

--3.CONDINATIONAL DELETE
--Delete users inactive for 2 years
DELETE FROM USERS 
WHERE LAST_LOGIN > CURRENT_DATE - INTERVAL '2YEARS';

--4.DELETE WITH RETURNING 
--REMOVE RECORDS AND RETURN WHAT WAS DELETED
DELETE FROM ORDERS 
WHERE STATUS ='DELAYED'
RETURNING *;

--5.CASCADING 
--TEST ON DELETE CASCADE WITH PARENT CHILD TABLES 
--PARENT TABLE 
CREATE TABLE CATEGORIES(
ID INT PRIMARY KEY,
NAME TEXT
);
INSERT INTO CATEGORIES
SELECT 
    GS,
	'CATEGORY_' || GS
FROM GENERATE_SERIES(1,5)AS GS;

--CHILD TABLE 
CREATE TABLE ITEMS(
ID INT PRIMARY KEY,
CATEGORY_ID INT REFERENCES CATEGORIES(ID) ON DELETE CASCADE
);
INSERT INTO ITEMS
SELECT 
    GS,
	GS
FROM GENERATE_SERIES(1,5)AS GS;

--DELETE PARENT 
DELETE FROM CATEGORIES WHERE ID = 1;










