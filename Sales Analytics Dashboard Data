--SALES ANALYTICS DASHBOARDS DATA 
CREATE TABLE REGIONS(
REGION_ID SERIAL PRIMARY KEY,
REGION_NAME VARCHAR(50)
);

INSERT INTO REGIONS(REGION_NAME)
SELECT 
'REGION' || GS
FROM GENERATE_SERIES(1,5)AS GS;

CREATE TABLE CUSTOMERS(
CUSTOMER_ID SERIAL PRIMARY KEY,
CUSTOMER_NAME VARCHAR(100),
REGION_ID INT REFERENCES REGIONS(REGION_ID)
);

INSERT INTO CUSTOMERS(CUSTOMER_NAME,REGION_ID)
SELECT 
'CUSTOMER_' || GS,
(GS%5)+1
FROM GENERATE_SERIES(1,20)AS GS;

CREATE TABLE PRODUCTS(
PRODUCT_ID SERIAL PRIMARY KEY ,
PRODUCT_NAME VARCHAR(100),
CATEGORY VARCHAR(100),
PRICE NUMERIC(10,2)
);

INSERT INTO products
SELECT id,
       'Product ' || id,
       CASE 
           WHEN id <= 3 THEN 'Electronics'
           WHEN id <= 6 THEN 'Clothing'
           ELSE 'Furniture'
       END,
       (100 + id * 20)
FROM generate_series(1,10) id;

CREATE TABLE SALES(
SAL_ID SERIAL PRIMARY KEY,
PRODUCT_ID INT REFERENCES PRODUCTS(PRODUCT_ID),
CUSTOMER_ID INT REFERENCES CUSTOMERS(CUSTOMER_ID),
SAL_DATE DATE,
QUANTITY INT,
AMOUNT NUMERIC
);

INSERT INTO SALES
SELECT
ID,
(ID % 10)+1,
(ID % 20)+1,
DATE '2024-01-01' + (ID % 180),
(ID % 5),
ID * 100
FROM GENERATE_SERIES(1,250)AS ID;

--QUERIES 
-- TOTAL SALES BY PRODUCTS CATEGORY  
SELECT P.CATEGORY,
       SUM(S.AMOUNT)AS TOTAL_SALES
FROM SALES S 
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID
GROUP BY P.CATEGORY;
--TOP 5 CUSTOMERS BY REVENUE 
SELECT CUSTOMER_ID,
       SUM(AMOUNT)AS REVENUE
FROM SALES 
GROUP BY CUSTOMER_ID
ORDER BY REVENUE DESC
LIMIT 5;
--MONTLY SALES TREND
SELECT DATE_TRUNC('MONTH',SAL_DATE)AS MONTH,
       SUM(AMOUNT)AS MONTHLY_SALES
FROM SALES 
GROUP BY MONTH
ORDER BY MONTH ;
--RUNNING TOTALS
SELECT SAL_DATE,
      SUM(AMOUNT) OVER (ORDER BY SAL_DATE)AS RUNNING_TOTAL
FROM SALES;

--SALES RANK BY REGION 
SELECT r.region_name,
       SUM(s.amount) AS total_sales,
       RANK() OVER (ORDER BY SUM(s.amount) DESC) AS rank
FROM sales s
JOIN customers c ON s.customer_id = c.customer_id
JOIN regions r ON c.region_id = r.region_id
GROUP BY r.region_name;
	   
