--E-COMMERCE INVENTORY SYSTEM
--SUPPLIERS TABLE
CREATE TABLE SUPPLIERS(
SUPPLIER_ID SERIAL PRIMARY KEY,
NAME VARCHAR(100),
EMAIL VARCHAR(150),
PHONE VARCHAR(20)
);
--PRODUCTS TABLE 
CREATE TABLE PRODUCTS(
PRODUCT_ID SERIAL PRIMARY KEY,
NAME VARCHAR(100),
PRICE NUMERIC(10,2)NOT NULL,
SUPPLIER_ID INT REFERENCES SUPPLIERS(SUPPLIER_ID) 
);
--WAREHOUSES TABLE
CREATE TABLE WAREHOUSES(
WAREHOUSE_ID SERIAL PRIMARY KEY,
NAME VARCHAR(100) NOT NULL,
LOCATION TEXT
);
--STOCK_LEVELS
CREATE TABLE STOCK_LEVELS(
STOCK_ID SERIAL PRIMARY KEY,
PRODUCT_ID INT REFERENCES PRODUCTS(PRODUCT_ID),
WAREHOUSE_ID INT REFERENCES WAREHOUSES(WAREHOUSE_ID),
QUANTITY INT DEFAULT 0

);

--INSERT 10 SUPLLIERS,50 PRODUCTS,5WARE HOUSES
INSERT INTO SUPPLIERS(NAME,EMAIL)
SELECT 
'PRODUCT_' ||G,
'PROD'||G|| '@GMAIL.COM'
FROM GENERATE_SERIES(1,10) G;

INSERT INTO PRODUCTS(NAME,PRICE,SUPPLIER_ID)
SELECT 
'PRODUCT_' || G,
G * 50,
(G%10)+1
FROM GENERATE_SERIES(1,50)G;

INSERT INTO WAREHOUSES(NAME)
SELECT
'WARE_HOUSE_' ||G
FROM GENERATE_SERIES(1,5)G;

INSERT INTO STOCK_LEVELS(PRODUCT_ID ,WAREHOUSE_ID ,QUANTITY )
SELECT P.PRODUCT_id, W.WAREHOUSE_ID, 100 
FROM PRODUCTS P CROSS JOIN WAREHOUSES W;

--QUERIES 
--GET ALL PRODUCTS WITH SUPPLIER NAME
SELECT P.PRODUCT_NAME,S.SUPPLIER_NAME,P.PRICE 
FROM PRODUCTS P 
JOIN SUPPLIERS S ON P.SUPPLIER_ID = S.SUPPLIER_ID ;

--TOTAL STOCK PER PRODUCT 
SELECT P.PRODUCT_NAME,SUM(S.QUANTITY)AS TOTAL_STOCK
FROM STOCK_LEVELS S 
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID 
GROUP BY P.PRODUCT_NAME;

--STOCK PER WAREHOUSE
SELECT W.NAME,SUM(S.QUANTITY)AS TOTAL_STOCK
FROM STOCK_LEVELS S
JOIN WAREHOUSES W ON S.WAREHOUSE_ID = W.WAREHOUSE_ID;
--LOW STOCK PRODUCTS 
SELECT P.PRODUCT_NAME,SUM(S.QUANTITY)AS TOTAL_STOCK
FROM STOCK_LEVELS S
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID 
GROUP BY P.PRODUCT_NAME
HAVING SUM(S.QUANTITY) < 50;

---PRODUCTS IN EACH WAREHOUSES 
SELECT W.NAME,P.PRODUCT_NAME,S.QUANTITY
FROM STOCK_LEVELS S
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID 
JOIN WAREHOUSES W ON S.WAREHOUSE_ID = W.WAREHOUSE_ID;

--MOST EXPENSIVE PRODUCT 
SELECT PRODUCT_NAME ,PRICE 
FROM PRODUCTS 
ORDER BY PRICE DESC 
LIMIT 1;

--TOTAL PRODUCTS PER SUPPLIER
SELECT s.supplier_name, COUNT(p.product_id) AS total_products
FROM suppliers s
LEFT JOIN products p ON s.supplier_id = p.supplier_id
GROUP BY s.supplier_name;

--TOTAL INVENTORY VALUE 
SELECT SUM(P.PRICE * S.QUANTITY)AS TOTAL_INVENTORY_VALUE 
FROM STOCK_LEVELS S
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID;

--OUT OF STOCK PRODUCTS 
SELECT P.PRODUCT_NAME 
FROM STOCK_LEVELS S 
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID 
WHERE S.QUANTITY = 0;

--TOP 5 PRODUCTS BY STOCK 
SELECT P.PRODUCT_NAME,SUM(S.QUANTITY)AS TOTAL_STOCK
FROM STOCK_LEVELS S 
JOIN PRODUCTS P ON S.PRODUCT_ID = P.PRODUCT_ID 
GROUP BY P.PRODUCT_NAME 
ORDER BY TOTAL_STOCK DESC
LIMIT 5;

